# =============================================================================
# DB-PER-SERVICE ARCHITECTURE
# Each service has its own PostgreSQL database
# Databases are created automatically on first start via init script
# =============================================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Redis Connection
REDIS_URL=redis://redis:6379

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Admin Web Default Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password

# Telegram Bot Configuration
# Get your token from BotFather: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here
TELEGRAM_API_KEY=test_api_key
# TELEGRAM_PROXY=
# For host machine proxy (e.g., localhost:1080), use:
# TELEGRAM_PROXY=socks5://host.docker.internal:1080

# Service-to-Service Authentication
SERVICE_API_KEY=mentor-bot-service-key

# Application secrets — generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Both must be at least 32 characters.
SECRET_KEY=replace_with_32_or_more_random_chars
JWT_SECRET_KEY=replace_with_32_or_more_random_chars

# =============================================================================
# GOOGLE OAUTH - Required for Google Calendar integration
# =============================================================================

GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5670/api/v1/calendar/callback

# =============================================================================
# EMAIL (SMTP) - Required for email notifications
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Timezone configuration
TZ=UTC

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# pgAdmin Credentials
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme

# =============================================================================
# Security — set these in production!
# =============================================================================

CORS_ORIGINS=["*"]
ALLOWED_HOSTS=["*"]
# Production example: include public hosts plus internal Docker DNS names used for service-to-service calls.
# ALLOWED_HOSTS=["yourdomain.com","www.yourdomain.com","localhost","auth_service","checklists_service","knowledge_service","notification_service","escalation_service","meeting_service","feedback_service"]

# =============================================================================
# Deployment
# =============================================================================
DOCKER_USERNAME=your_dockerhub_username
IMAGE_TAG=latest
# Per-service image tags (optional, defaults to IMAGE_TAG)
# TELEGRAM_BOT_TAG=latest
# ADMIN_WEB_TAG=latest
# AUTH_SERVICE_TAG=latest
# CHECKLISTS_SERVICE_TAG=latest
# KNOWLEDGE_SERVICE_TAG=latest
# NOTIFICATION_SERVICE_TAG=latest
# FEEDBACK_SERVICE_TAG=latest
# ESCALATION_SERVICE_TAG=latest
# MEETING_SERVICE_TAG=latest

# =============================================================================
# S3-Compatible Storage (MinIO, AWS S3, etc.)
# =============================================================================

S3_ENDPOINT=http://minio:9000
# Note: S3_ACCESS_KEY / S3_SECRET_KEY MUST match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
# (the S3 client uses these to authenticate against the MinIO container).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false
S3_SECURE_MODE=false
S3_PRESIGNED_URL_EXPIRY=3600

KNOWLEDGE_S3_BUCKET=knowledge-files
CHECKLISTS_S3_BUCKET=checklists-files

# =============================================================================
# Production Resource Limits and Load Tuning
# =============================================================================

# Container memory limits used by docker-compose.prod.yml.
PYTHON_SERVICE_MEM_LIMIT=220m
PYTHON_SERVICE_MEM_RESERVATION=120m
ADMIN_WEB_MEM_LIMIT=350m
ADMIN_WEB_MEM_RESERVATION=200m
POSTGRES_MEM_LIMIT=700m
POSTGRES_MEM_RESERVATION=400m
REDIS_MEM_LIMIT=100m
REDIS_MEM_RESERVATION=64m
MINIO_MEM_LIMIT=256m
MINIO_MEM_RESERVATION=128m

# PostgreSQL runtime settings. Keep service DB pools aligned with max_connections.
POSTGRES_MAX_CONNECTIONS=60
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=768MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_WORK_MEM=8MB
DATABASE_POOL_SIZE=3
DATABASE_MAX_OVERFLOW=2

# Redis runtime settings.
REDIS_MAXMEMORY=64mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Limit concurrent checklist setup requests during `make mock-data`.
MOCK_DATA_CHECKLIST_CONCURRENCY=2

# =============================================================================
# Per-service Auth Service URLs (used for cross-service communication)
# =============================================================================

ADMIN_WEB_URL=http://localhost:3000
AUTH_SERVICE_URL=http://auth_service:8000
CHECKLISTS_SERVICE_URL=http://checklists_service:8000
KNOWLEDGE_SERVICE_URL=http://knowledge_service:8000
NOTIFICATION_SERVICE_URL=http://notification_service:8000
ESCALATION_SERVICE_URL=http://escalation_service:8000
FEEDBACK_SERVICE_URL=http://feedback_service:8000
MEETING_SERVICE_URL=http://meeting_service:8000
