# =============================================================================
# REQUIRED VARIABLES - Must be set for the application to function properly
# =============================================================================

# PostgreSQL Database Configuration
POSTGRES_DB=mentor_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Redis Connection
REDIS_URL=redis://redis:6379

# Telegram Bot Configuration
# Get your token from BotFather: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here
TELEGRAM_API_KEY=test_api_key

# Service-to-Service Authentication
SERVICE_API_KEY=mentor-bot-service-key

# =============================================================================
# GOOGLE OAUTH - Required for Google Calendar integration in meeting_service
# =============================================================================

# Google OAuth 2.0 Credentials
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5670/auth/google/callback

# =============================================================================
# EMAIL (SMTP) - Required for email notifications
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# =============================================================================
# OPTIONAL VARIABLES - Have sensible defaults but can be customized
# =============================================================================

# Timezone configuration
# default: UTC
TZ=UTC

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# pgAdmin Credentials (optional, for development only)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme

# =============================================================================
# S3-Compatible Storage Configuration (MinIO, AWS S3, etc.)
# =============================================================================

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false
# Set to false for local development with HTTP (e.g., local MinIO)
# Set to true in production with HTTPS endpoints
S3_SECURE_MODE=false
S3_PRESIGNED_URL_EXPIRY=3600

# Service-specific S3 buckets
KNOWLEDGE_S3_BUCKET=knowledge-files
CHECKLISTS_S3_BUCKET=checklists-files
