{
  "Servers": {
    "1": {
      "Group": "Auth Service",
      "Name": "auth_db",
      "Host": "postgres",
      "Port": 5432,
      "MaintenanceDB": "auth_db",
      "Username": "${POSTGRES_USER}",
      "UseSSHTunnel": 0,
      "TunnelPort": "22",
      "TunnelAuthentication": 0,
      "KerberosAuthentication": false,
      "ConnectionParameters": {
        "sslmode": "prefer",
        "connect_timeout": 10,
        "passfile": "/pgpass"
