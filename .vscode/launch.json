{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "telegram_bot_debug",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5670
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/telegram_bot/telegram_bot",
          "remoteRoot": "/app/telegram_bot"
        }
      ]
    },
    {
      "name": "auth_service_debug",
