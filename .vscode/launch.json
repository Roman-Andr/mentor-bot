{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Knowledge Service (Docker)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/knowledge_service/knowledge_service",
          "remoteRoot": "/knowledge_service/knowledge_service"
        }
      ]
    }
  ]
}
