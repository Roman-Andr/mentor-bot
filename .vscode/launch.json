          "remoteRoot": "/app/meeting_service"
        }
      ]
    },
    {
      "name": "admin_web_debug_server",
      "type": "node",
      "request": "attach",
      "address": "localhost",
      "port": 9229,
      "localRoot": "${workspaceFolder}/admin_web",
      "remoteRoot": "/app",
      "restart": true
    },
    {
      "name": "admin_web_debug_client",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "cwd": "${workspaceFolder}/admin_web",
      "webRoot": "${workspaceFolder}/admin_web",
      "sourceMaps": true
